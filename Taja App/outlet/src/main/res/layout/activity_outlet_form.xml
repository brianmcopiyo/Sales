<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iphone_xxs04_activity_constraint_layout_constraint_layout_background_color">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/outlet_form_save"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/outlet_form_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/restock_back"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_chevron_back"
                android:drawableTint="@color/color_primary"
                android:drawablePadding="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/outlet_form_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/outlet_form_title"
                android:textColor="@color/color_primary"
                android:fontFamily="sans-serif-medium"
                android:textSize="20sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/outlet_name_hint"
                android:textColor="@color/restock_input_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/outlet_form_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="1"
                android:inputType="text"
                android:background="@drawable/restock_input_background"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="@color/restock_input_text"
                android:textColorHint="@color/restock_input_hint"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/outlet_code_hint"
                android:textColor="@color/restock_input_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/outlet_form_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="1"
                android:inputType="text"
                android:background="@drawable/restock_input_background"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="@color/restock_input_text"
                android:textColorHint="@color/restock_input_hint"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/outlet_address_hint"
                android:textColor="@color/restock_input_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/outlet_form_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="2"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:background="@drawable/restock_input_background"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="@color/restock_input_text"
                android:textColorHint="@color/restock_input_hint"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/outlet_location_label"
                android:textColor="@color/restock_input_hint"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/outlet_form_location_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/outlet_location_get"
                android:textColor="@color/restock_input_text"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/outlet_form_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save"
        android:textColor="@color/white"
        android:background="@drawable/logout_button_background"
        android:fontFamily="sans-serif-medium"
        android:textSize="14sp"
        android:padding="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ProgressBar
        android:id="@+id/outlet_form_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/color_primary"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="gone"/>
</androidx.constraintlayout.widget.ConstraintLayout>
