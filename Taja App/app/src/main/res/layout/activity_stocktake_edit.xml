<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iphone_xxs04_activity_constraint_layout_constraint_layout_background_color">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/stocktake_edit_complete"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/stocktake_edit_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/restock_back"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:drawableStart="@drawable/ic_chevron_back"
                android:drawablePadding="6dp"
                android:paddingStart="4dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_add_product"
                android:textColor="@color/color_primary"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <Spinner
                    android:id="@+id/stocktake_edit_add_product"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:background="@drawable/restock_input_background"/>
                <Button
                    android:id="@+id/stocktake_edit_add_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stocktake_add_product"
                    android:textColor="@color/color_primary"
                    android:background="?attr/selectableItemBackground"
                    android:textSize="12sp"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_closing_stock_hint"
                android:textColor="@color/restock_input_hint"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:id="@+id/stocktake_edit_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/stocktake_edit_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/stocktake_complete"
        android:background="@drawable/logout_button_background"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-medium"
        android:textSize="14sp"
        android:padding="14dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ProgressBar
        android:id="@+id/stocktake_edit_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/color_primary"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
