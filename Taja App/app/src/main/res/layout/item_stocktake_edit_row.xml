<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/restock_input_background"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/row_edit_product_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_primary"
        android:textSize="14sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_opening_stock"
            android:textSize="12sp"
            android:textColor="@color/restock_input_hint"/>
        <TextView
            android:id="@+id/row_edit_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/restock_input_text"
            android:layout_marginStart="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_physical_count"
            android:textSize="12sp"
            android:textColor="@color/restock_input_hint"
            android:layout_marginStart="12dp"/>
        <TextView
            android:id="@+id/row_edit_physical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/restock_input_text"
            android:layout_marginStart="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_variance"
            android:textSize="12sp"
            android:textColor="@color/restock_input_hint"
            android:layout_marginStart="12dp"/>
        <TextView
            android:id="@+id/row_edit_variance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/restock_input_text"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:layout_marginTop="8dp">
        <Button
            android:id="@+id/row_edit_count_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_enter_count"
            android:background="@drawable/logout_button_background"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:layout_marginEnd="8dp"/>
        <Button
            android:id="@+id/row_edit_remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_remove_item"
            android:textColor="@color/color_logout_red"
            android:background="?attr/selectableItemBackground"
            android:textSize="12sp"
            android:padding="8dp"/>
    </LinearLayout>
</LinearLayout>
