<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/iphone_xxs04_activity_constraint_layout_constraint_layout_background_color">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboard_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <!-- Header: greeting + subtitle -->
            <TextView
                android:id="@+id/dashboard_title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
            <TextView
                android:id="@+id/dashboard_welcome_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/restock_input_text"
                android:textSize="20sp"
                android:letterSpacing="-0.01"
                tools:text="Hello, John" />
            <TextView
                android:id="@+id/dashboard_branch_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/restock_input_hint"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone"
                tools:text="Branch: Main Store"
                tools:visibility="visible" />

            <!-- Highlight card: Orders awaiting approval -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_highlight_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_orders_awaiting_approval"
                        android:textColor="@color/color_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />
                    <TextView
                        android:id="@+id/stat_pending_restock_orders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/restock_input_text"
                        android:textSize="18sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Section: Today's overview -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_todays_overview"
                android:textColor="@color/color_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <!-- 2x2 data grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/label_sales_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_sales_today"
                            android:textColor="@color/restock_input_hint"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/stat_sales_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/label_sales_today" />
                        <TextView android:id="@+id/stat_sales_today_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_sales_total_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_sales_total" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_sales_month_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_sales_month" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="16dp"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:id="@+id/label_low_stock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_low_stock"
                            android:textColor="@color/restock_input_hint"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/stat_low_stock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/label_low_stock" />
                        <TextView android:id="@+id/stat_low_stock_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_out_of_stock_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_out_of_stock" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/label_revenue_month"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_revenue"
                            android:textColor="@color/restock_input_hint"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/stat_revenue_month"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/label_revenue_month" />
                        <TextView android:id="@+id/stat_revenue_month_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_revenue_total_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_revenue_total" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="16dp"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:id="@+id/label_tickets_open"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_open_tickets"
                            android:textColor="@color/restock_input_hint"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/stat_tickets_open"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/label_tickets_open" />
                        <TextView android:id="@+id/stat_tickets_open_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_tickets_total_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/stat_tickets_total" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Devices -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_devices"
                android:textColor="@color/color_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/dashboard_card_rounded"
                android:padding="16dp"
                android:minHeight="56dp"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/stat_devices_available_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/dashboard_available_devices"
                    android:textColor="@color/restock_input_hint"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/stat_devices_available"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/restock_input_text"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/stat_devices_available_label" />
                <TextView
                    android:id="@+id/stat_devices_total_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="Total"
                    android:textColor="@color/restock_input_hint"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/stat_devices_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/restock_input_text"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/stat_devices_total_label" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Pending transfers + Stock takes row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_transfers"
                        android:textColor="@color/color_primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="14dp"
                        android:minHeight="52dp">
                        <TextView
                            android:id="@+id/stat_pending_transfers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp" />
                    </FrameLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stocktake_list_title"
                        android:textColor="@color/color_primary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp" />
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/dashboard_card_rounded"
                        android:padding="14dp"
                        android:minHeight="52dp">
                        <TextView
                            android:id="@+id/stat_pending_stock_takes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="@color/restock_input_text"
                            android:textSize="18sp" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/bottom_navigation"
        layout="@layout/bottom_navigation_include"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/dashboard_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/color_primary"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/dashboard_loading_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/loading_loading"
        android:textColor="@color/color_primary"
        android:textSize="14sp"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dashboard_progress"
        tools:visibility="visible" />
</androidx.constraintlayout.widget.ConstraintLayout>
