<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bottomsheet_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/receive_sheet_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/receive_stock_title"
            android:textColor="@color/color_primary"
            android:fontFamily="sans-serif-medium"
            android:textSize="18sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/receive_product_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/receive_order_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/restock_input_hint"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/receive_quantity_received_label"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/receive_quantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint=""
            android:padding="12dp"
            android:background="@drawable/restock_input_background"
            android:textColor="@color/restock_input_text"
            android:textColorHint="@color/restock_input_hint"
            android:textSize="14sp"
            android:inputType="number"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/receive_quantity_max"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/restock_input_hint"
            android:textSize="12sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/receive_notes_label"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/receive_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="@string/receive_notes_placeholder"
            android:padding="12dp"
            android:background="@drawable/restock_input_background"
            android:textColor="@color/restock_input_text"
            android:textColorHint="@color/restock_input_hint"
            android:textSize="14sp"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="500"
            android:maxLines="3"
            android:gravity="top|start"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/receive_imei_label"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/receive_imeis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:hint="@string/receive_imei_placeholder"
            android:padding="12dp"
            android:background="@drawable/restock_input_background"
            android:textColor="@color/restock_input_text"
            android:textColorHint="@color/restock_input_hint"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:maxLength="2000"
            android:maxLines="4"
            android:gravity="top|start"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/receive_imei_upload_csv_hint"
            android:textColor="@color/restock_input_hint"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/receive_imei_upload_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/receive_imei_upload_csv"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/receive_imei_scan_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/receive_imei_scan_barcode"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"/>
        </LinearLayout>

        <CheckBox
            android:id="@+id/receive_mark_complete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/receive_mark_complete_label"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:padding="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/receive_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@android:string/cancel"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/receive_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/record_receipt"
                android:textColor="#FFFFFF"
                android:background="@drawable/logout_button_background"
                android:textSize="14sp"
                android:padding="12dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
