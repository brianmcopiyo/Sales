<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/restock_input_background"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/item_stocktake_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_primary"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/item_stocktake_branch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_text"
        android:textSize="13sp"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/item_stocktake_date_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_hint"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/item_stocktake_counts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_hint"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>
</LinearLayout>
