<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/restock_input_background"
    android:padding="12dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/item_order_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/color_primary"
        android:textSize="14sp"/>

    <TextView
        android:id="@+id/item_order_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_text"
        android:textSize="13sp"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/item_order_branch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_hint"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/item_order_qty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_hint"
        android:textSize="12sp"
        android:layout_marginTop="2dp"/>

    <LinearLayout
        android:layout_marginTop="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Second row: partial / full -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/item_btn_approve_full"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_approve_full"
                android:textColor="#FFFFFF"
                android:background="@drawable/logout_button_background"
                android:textSize="12sp"
                android:padding="4dp"/>

            <Button
                android:id="@+id/item_btn_approve_partial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_approve_partial"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/item_btn_mark_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_mark_complete_button"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/item_btn_edit_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_edit_quantity_button"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginEnd="4dp"/>

        </LinearLayout>

        <!-- First row: edit / complete / reject -->
        <LinearLayout
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start">


            <Button
                android:id="@+id/item_btn_reject"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/orders_reject"
                android:textColor="@color/color_logout_red"
                android:background="?attr/selectableItemBackground"
                android:textSize="12sp"
                android:padding="4dp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
