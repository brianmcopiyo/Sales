<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bottomsheet_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/count_sheet_product"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/color_primary"
            android:fontFamily="sans-serif-medium"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_opening_stock"
            android:textColor="@color/restock_input_hint"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:id="@+id/count_sheet_system"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_physical_count"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/count_sheet_physical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="0"
            android:padding="12dp"
            android:background="@drawable/restock_input_background"
            android:textColor="@color/restock_input_text"
            android:textColorHint="@color/restock_input_hint"
            android:textSize="14sp"
            android:inputType="number"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_imei_optional"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/count_sheet_imei"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"
            android:hint="@string/receive_imei_placeholder"
            android:padding="12dp"
            android:background="@drawable/restock_input_background"
            android:textColor="@color/restock_input_text"
            android:textColorHint="@color/restock_input_hint"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:gravity="top|start"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/count_sheet_scan_imei"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_scan_imei"
            android:textColor="@color/color_primary"
            android:background="?attr/selectableItemBackground"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/count_sheet_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@android:string/cancel"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/count_sheet_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_save_count"
                android:textColor="#FFFFFF"
                android:background="@drawable/logout_button_background"
                android:textSize="14sp"
                android:padding="12dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
