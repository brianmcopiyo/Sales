<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/review_imei_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_imei_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/color_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/review_imei_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/review_imei_subtitle"
        android:textSize="14sp"
        android:textColor="@color/restock_input_hint"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/review_imei_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/restock_input_text"
            android:textSize="14sp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/review_imei_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@android:string/cancel"
            android:textColor="@color/color_primary"
            android:background="?attr/selectableItemBackground"
            android:padding="12dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/review_imei_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/review_imei_confirm"
            android:textColor="@android:color/white"
            android:background="@drawable/logout_button_background"
            android:padding="12dp" />
    </LinearLayout>

</LinearLayout>

