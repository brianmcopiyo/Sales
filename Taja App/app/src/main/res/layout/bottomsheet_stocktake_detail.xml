<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottomsheet_background"
    android:padding="20dp">

    <!-- Drag handle (UX: signals sheet can be dismissed by swipe) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/restock_input_hint"
        android:alpha="0.5"
        android:layout_marginBottom="16dp"/>

    <!-- Header: title + status + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/stocktake_sheet_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_primary"
                android:fontFamily="sans-serif-medium"
                android:textSize="18sp"/>
            <TextView
                android:id="@+id/stocktake_sheet_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/stocktake_sheet_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/restock_input_hint"
            android:background="?attr/selectableItemBackground"
            android:textSize="20sp"
            android:minWidth="48dp"
            android:minHeight="48dp"/>
    </LinearLayout>

    <!-- Loading: visible at top while fetching -->
    <ProgressBar
        android:id="@+id/stocktake_sheet_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/color_primary"
        android:visibility="gone"
        android:layout_marginBottom="8dp"/>

    <!-- Metadata: branch · date -->
    <TextView
        android:id="@+id/stocktake_sheet_branch_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_hint"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <!-- Summary stats (at-a-glance before detail list) -->
    <TextView
        android:id="@+id/stocktake_sheet_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/restock_input_text"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="12dp"/>

    <!-- Hint when user can edit but hasn\'t completed counts yet -->
    <TextView
        android:id="@+id/stocktake_sheet_complete_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/stocktake_complete_hint"
        android:textColor="@color/restock_input_hint"
        android:textSize="12sp"
        android:visibility="gone"
        android:layout_marginBottom="12dp"/>

    <!-- Section: Items (subheader + list) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stocktake_items"
        android:textColor="@color/color_primary"
        android:fontFamily="sans-serif-medium"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/stocktake_sheet_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- Actions: primary first, then secondary, destructive last -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/restock_input_hint"
        android:alpha="0.3"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">
            <Button
                android:id="@+id/stocktake_sheet_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_complete"
                android:textColor="#FFFFFF"
                android:background="@drawable/logout_button_background"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/stocktake_sheet_approve"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_approve"
                android:textColor="#FFFFFF"
                android:background="@drawable/logout_button_background"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginTop="8dp">
            <Button
                android:id="@+id/stocktake_sheet_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_edit"
                android:textColor="@color/color_primary"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>
            <Button
                android:id="@+id/stocktake_sheet_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stocktake_cancel"
                android:textColor="@color/color_logout_red"
                android:background="?attr/selectableItemBackground"
                android:textSize="14sp"
                android:padding="12dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
