<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottomsheet_background"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stocktake_cancel"
        android:textColor="@color/color_primary"
        android:fontFamily="sans-serif-medium"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stocktake_cancel_confirm"
        android:textColor="@color/restock_input_text"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/stocktake_cancel_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:hint="@string/stocktake_cancel_reason_hint"
        android:padding="12dp"
        android:background="@drawable/restock_input_background"
        android:textColor="@color/restock_input_text"
        android:textColorHint="@color/restock_input_hint"
        android:textSize="14sp"
        android:inputType="textCapSentences|textMultiLine"
        android:maxLines="4"
        android:gravity="top|start"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/stocktake_cancel_sheet_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@android:string/cancel"
            android:textColor="@color/color_primary"
            android:background="?attr/selectableItemBackground"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/stocktake_cancel_sheet_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stocktake_cancel"
            android:textColor="#FFFFFF"
            android:background="@drawable/logout_button_solid"
            android:textSize="14sp"
            android:padding="12dp"/>
    </LinearLayout>
</LinearLayout>
