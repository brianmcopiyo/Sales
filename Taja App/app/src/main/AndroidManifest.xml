<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.taja.app">

    <uses-sdk
        android:minSdkVersion="21"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="false"
        tools:replace="android:required" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <!-- Ensure Play Services activity has android:exported for AGP 8 merger -->
        <activity
            android:name="com.google.android.gms.common.api.GoogleApiActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            tools:node="merge"
            tools:replace="android:exported" />
        <activity
            android:name="com.taja.app.activity.LoginActivity"
            android:label=""
            android:theme="@style/IPhoneXXS04ActivityTheme"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.taja.app.activity.DashboardActivity"
            android:label="@string/dashboard_title"
            android:theme="@style/AppTheme"
            android:exported="false"/>
        <activity
            android:name="com.taja.app.activity.OutletsListActivity"
            android:label="@string/outlets_title"
            android:theme="@style/AppTheme"
            android:exported="false"/>
        <activity
            android:name="com.taja.app.activity.ProfileActivity"
            android:label="@string/nav_profile"
            android:theme="@style/AppTheme"
            android:exported="false"/>
        <activity
            android:name="com.taja.app.activity.OtpActivity"
            android:label=""
            android:theme="@style/IPhoneXXS04ActivityTheme"
            android:exported="false"/>
    </application>

</manifest>
